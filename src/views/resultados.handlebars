<h1>🏁 Resultados de Franco Colapinto</h1>

<p>
  En esta sección se administran los resultados por carrera del piloto.
  Los datos se almacenan en una base de datos y pueden ser agregados,
  editados o eliminados.
</p>

<hr>

<h2>➕ Agregar nuevo resultado</h2>

<form action="/resultados/agregar" method="POST">
  <input type="text" name="gran_premio" placeholder="Gran Premio" required>
  <input type="text" name="circuito" placeholder="Circuito" required>
  <input type="number" name="posicion" placeholder="Posición final" required>
  <input type="number" name="puntos" placeholder="Puntos obtenidos" required>
  <input type="number" name="temporada" placeholder="Temporada (año)" required>

  <button type="submit">Agregar resultado</button>
</form>

<hr>

<h2>📊 Resultados cargados</h2>

{{#if resultados.length}}
<table border="1" cellpadding="10">
  <tr>
    <th>Gran Premio</th>
    <th>Circuito</th>
    <th>Posición</th>
    <th>Puntos</th>
    <th>Temporada</th>
    <th>Acciones</th>
  </tr>

  {{#each resultados}}
  <tr>
    <td>{{this.gran_premio}}</td>
    <td>{{this.circuito}}</td>
    <td>{{this.posicion}}</td>
    <td>{{this.puntos}}</td>
    <td>{{this.temporada}}</td>
    <td>
      <a href="/resultados/editar/{{this.id}}">✏️ Editar</a>

      <form action="/resultados/eliminar/{{this.id}}" method="POST" style="display:inline;">
        <button type="submit">🗑️ Eliminar</button>
      </form>
    </td>
  </tr>
  {{/each}}
</table>
{{else}}
<p>No hay resultados cargados.</p>
{{/if}}