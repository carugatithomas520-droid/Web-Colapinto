<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <title>F1 – Franco Colapinto</title>

  <style>
    body {
      font-family: 'Segoe UI', sans-serif;
      background: #f4f4f4;
      margin: 0;
      padding: 0;
    }

    header {
      background: #c00;
      color: white;
      padding: 20px;
    }

    header h1 {
      margin: 0;
    }

    nav {
      margin-top: 10px;
    }

    nav a {
      color: white;
      margin-right: 15px;
      text-decoration: none;
      font-weight: bold;
    }

    nav a:hover {
      text-decoration: underline;
    }

    main {
      padding: 30px;
      background: white;
      min-height: 80vh;
    }

    footer {
      background: #222;
      color: #aaa;
      text-align: center;
      padding: 10px;
    }

    input, textarea, button {
      display: block;
      margin: 10px 0;
      padding: 8px;
      width: 300px;
      max-width: 100%;
    }

    button {
      background: #c00;
      color: white;
      border: none;
      cursor: pointer;
    }

    button:hover {
      background: #900;
    }

    ul {
      padding-left: 20px;
    }

    li {
      margin-bottom: 10px;
    }
  </style>
</head>
<body>

<header>
  <h1>🏁 Perfil de Piloto F1</h1>
  <nav>
    <a href="/">Home</a>
    <a href="/pilotos">Resultados</a>
    <a href="/contacto">Contacto</a>
  </nav>
</header>

<main>
  {{{body}}}
</main>

<footer>
  Proyecto curso Node.js – Handlebars – Base de Datos
</footer>

</body>
</html>