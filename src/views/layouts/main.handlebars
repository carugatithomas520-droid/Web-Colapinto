<!DOCTYPE html>

<html lang="es">

<head>

    <meta charset="UTF-8">

    <title>Franco Colapinto | Alpine F1 Team</title>

    <style>

        body {

            margin: 0;

            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;

            background-color: #001026; /* Fondo azul muy oscuro de Alpine */

            color: #ffffff;

        }

       

        header {

            background-color: #002e6e; /* Azul Alpine */

            color: white;

            padding: 30px 20px;

            border-bottom: 5px solid #ff0055; /* Rosa Alpine */

            text-align: center;

        }

       

        header h1 {

            margin: 0;

            font-size: 3.5em;

            text-transform: uppercase;

            letter-spacing: 3px;

            font-weight: 800;

        }

       

        nav { margin-top: 20px; }

       

        nav a {

            color: white;

            margin: 0 15px;

            text-decoration: none;

            font-weight: bold;

            text-transform: uppercase;

            font-size: 1.1em;

            letter-spacing: 1px;

            padding: 5px 10px;

            transition: all 0.3s;

        }

       

        nav a:hover {

            color: #ff0055; /* Rosa al pasar el mouse */

            border-bottom: 2px solid #ff0055;

        }

       

        main {

            background: #00193d; /* Azul ligeramente más claro para el contenido */

            padding: 40px;

            min-height: 80vh;

            max-width: 1200px;

            margin: 20px auto;

            border-radius: 10px;

            border: 1px solid #0056b3;

        }

       

        footer {

            background: #000;

            color: #aaa;

            text-align: center;

            padding: 20px;

            font-size: 0.9em;

            border-top: 1px solid #ff0055;

        }

    </style>

</head>

<body>

    <header>

        <h1>🏁 Franco Colapinto</h1>

        <nav>

            <a href="/">Inicio</a>

            <a href="/pilotos">El piloto</a>

            <a href="/resultados">Resultados</a>

            <a href="/contacto">Contacto</a>

        </nav>

    </header>

   

    <main>

        {{{body}}}

    </main>

   

    <footer>

        © 2026 - Fan Site no oficial - Alpine F1 Team

    </footer>

</body>

</html>