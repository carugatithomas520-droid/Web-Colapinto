<h1>📩 Contacto</h1>
<form method="POST" action="/contacto">
  <input type="text" name="nombre" placeholder="Nombre" style="display:block; width:100%; margin-bottom:10px; padding:8px;" required>
  <input type="email" name="email" placeholder="Email" style="display:block; width:100%; margin-bottom:10px; padding:8px;" required>
  <textarea name="mensaje" placeholder="Tu mensaje" style="display:block; width:100%; margin-bottom:10px; padding:8px;" rows="5" required></textarea>
  <button type="submit" style="background:#c00; color:white; padding:10px 20px; border:none; cursor:pointer;">Enviar Mensaje</button>
</form>